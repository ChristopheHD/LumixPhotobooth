{
  "name": "photobooth",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "description": "A minimal Electron application",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:css && electron main.js --no-sandbox --ignore-gpu-blocklist --enable-gpu-rasterization --enable-zero-copy --ozone-platform=x11 --disable-vulkan",
    "build:css": "sass app/sass/style.scss app/css/style.css && postcss app/css/style.css -o app/css/style.css",
    "watch:css": "sass --watch app/sass/style.scss app/css/style.css",
    "dist": "npm run build:css && electron-packager . --out=dist --overwrite --linux",
    "lint": "eslint .",
    "test": "node test/smoke-test.js"
  },
  "keywords": [
    "Electron",
    "quick",
    "start",
    "tutorial"
  ],
  "author": "GitHub",
  "license": "CC0-1.0",
  "bugs": {
    "url": "https://github.com/atom/electron-quick-start/issues"
  },
  "homepage": "https://github.com/atom/electron-quick-start#readme",
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.5.2",
    "electron": "^43.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "postcss-cli": "^11.0.1",
    "postcss-sort-media-queries": "^6.6.2",
    "sass": "^1.65.1",
    "through2": "^5.0.4"
  },
  "dependencies": {
    "jquery": "^4.0.0",
    "node-wifi": "^2.0.16",
    "xml2js": "^0.6.2"
  }
}
